+  set(CVPY_SUFFIX "${OPENCV_PYTHON3_EXT_SUFFIX}")
+elseif(DEFINED ${PYTHON}_CVPY_SUFFIX)
   set(CVPY_SUFFIX "${${PYTHON}_CVPY_SUFFIX}")
 else()
   set(__python_ext_suffix_var "EXT_SUFFIX")
